# LLM_API_KEY is optional and enables AI decoy generation when adding questions.
LLM_API_KEY=

# SECRET_KEY protects local session encryption and should be changed before any shared deployment.
SECRET_KEY=local-development-session-secret-change-before-deployment

# ADMIN_PASSWORD is the default password for the admin dashboard.
ADMIN_PASSWORD=admin123!

# PORT is the local web address port used by the backend.
PORT=8080
