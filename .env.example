# 3D Ambi Configuration

# Server Port
PORT=8080

# Admin Credentials (Seeded on first run)
# ADMIN_USER=your_chosen_admin_username
# ADMIN_PASSWORD_HASH=your_bcrypt_password_hash
# (Generate hash via: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())")

# Security Configuration
# FLASK_SECRET=your_random_flask_secret_key
# (Generate secret via: python -c "import secrets; print(secrets.token_hex(32))")
# SECURE_COOKIES=false # Set to true in production/HTTPS environments

# LLM Decoy Generation (Optional)
# OPENAI_API_KEY=your_key_here
# LLM_MODEL=gpt-4-turbo
